# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4 <Use the Development name instead>
AZURE_OPENAI_API_VERSION=2024-02-01

# FMU Configuration
FMU_PATH=models/fmus/

# Guardrail Configuration
# Enable/disable guardrails for tool validation (dynamic/runtime checks only)
# Deterministic invariants are validated via Pydantic model validators
GUARDRAILS_ENABLED=true

